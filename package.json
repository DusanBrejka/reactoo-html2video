{
  "name": "reactoo-html2video",
  "private": true,
  "description": "Render HTML overlay templates to video (WebM, ProRes, APNG, MP4) — Lambda + local CLI",
  "scripts": {
    "predeploy": "node scripts/fetch-ffmpeg.js && node scripts/fetch-chromium-layer.js && node scripts/build-ffmpeg-layer.js",
    "render": "node render-transparent-webm.js",
    "deploy": "npm run predeploy && serverless deploy",
    "upload-template": "node scripts/upload-template.js",
    "invoke": "node scripts/invoke-render.js",
    "smoke": "node scripts/upload-template.js && node scripts/invoke-render.js",
    "check-exit": "node scripts/check-exit-phase.js"
  },
  "engines": {
    "node": ">=16.13.2"
  },
  "dependencies": {
    "@sparticuz/chromium-min": "^121.0.0",
    "puppeteer-core": "^21.11.0"
  },
  "devDependencies": {
    "serverless": "^3.38.0"
  }
}
